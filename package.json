{
  "name": "@cludz/sdk",
  "description": "Cludz API JavaScript SDK",
  "version": "0.2.7",
  "type": "module",
  "private": false,
  "files": [
    "modules",
    "dist",
    "index.ts"
  ],
  "module": "./dist/index.js",
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "bunup index.ts --format cjs,esm,iife --minify",
    "dev": "bunup index.ts --format cjs,esm,iife --watch --dts",
    "lint": "bunx eslint ."
  },
  "devDependencies": {
    "@types/bun": "latest",
    "bunup": "^0.16.29"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/mee-i/cludz-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/mee-i/cludz-sdk/issues"
  },
  "homepage": "https://github.com/mee-i/cludz-sdk#readme"
}
